{% assign anpc_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .anpc-images-{{ anpc_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
  }

  .anpc-images-container-{{ anpc_id }} {
    display: flex;
    flex-direction: column;
    gap: {{ block.settings.spacing }}px;
  }

  .anpc-image-wrapper-{{ anpc_id }} {
    display: block;
    width: 100%;
    overflow: hidden;
    border-radius: {{ block.settings.border_radius }}px;
  }

  .anpc-image-{{ anpc_id }} {
    width: 100%;
    height: auto;
    display: block;
    transition: transform 0.3s ease;
  }

  .anpc-image-wrapper-{{ anpc_id }}:hover .anpc-image-{{ anpc_id }} {
    transform: scale(1.05);
  }

  .anpc-img-placeholder-{{ anpc_id }} {
    width: 100%;
    aspect-ratio: 16 / 9;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: {{ block.settings.border_radius }}px;
    position: relative;
  }

  .anpc-img-placeholder-{{ anpc_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 300px;
    max-height: 300px;
  }

  .anpc-empty-state-{{ anpc_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    padding: 12px 20px;
    font-size: 14px;
    color: #666;
    text-align: center;
    pointer-events: none;
  }
{% endstyle %}

<div class="anpc-images-{{ anpc_id }}" {{ block.shopify_attributes }}>
  <div class="anpc-images-container-{{ anpc_id }}">
    {% if block.settings.image_1_link != blank %}
      <a href="{{ block.settings.image_1_link }}" class="anpc-image-wrapper-{{ anpc_id }}">
        {% if block.settings.image_1 %}
          <img
            src="{{ block.settings.image_1 | image_url: width: 2000 }}"
            alt="{{ block.settings.image_1.alt | escape }}"
            loading="lazy"
            width="{{ block.settings.image_1.width }}"
            height="{{ block.settings.image_1.height }}"
            class="anpc-image-{{ anpc_id }}"
          >
        {% else %}
          <div class="anpc-img-placeholder-{{ anpc_id }}">
            {{ 'image' | placeholder_svg_tag }}
            <div class="anpc-empty-state-{{ anpc_id }}">
              Add first image
            </div>
          </div>
        {% endif %}
      </a>
    {% else %}
      <div class="anpc-image-wrapper-{{ anpc_id }}">
        {% if block.settings.image_1 %}
          <img
            src="{{ block.settings.image_1 | image_url: width: 2000 }}"
            alt="{{ block.settings.image_1.alt | escape }}"
            loading="lazy"
            width="{{ block.settings.image_1.width }}"
            height="{{ block.settings.image_1.height }}"
            class="anpc-image-{{ anpc_id }}"
          >
        {% else %}
          <div class="anpc-img-placeholder-{{ anpc_id }}">
            {{ 'image' | placeholder_svg_tag }}
            <div class="anpc-empty-state-{{ anpc_id }}">
              Add first image
            </div>
          </div>
        {% endif %}
      </div>
    {% endif %}

    {% if block.settings.image_2_link != blank %}
      <a href="{{ block.settings.image_2_link }}" class="anpc-image-wrapper-{{ anpc_id }}">
        {% if block.settings.image_2 %}
          <img
            src="{{ block.settings.image_2 | image_url: width: 2000 }}"
            alt="{{ block.settings.image_2.alt | escape }}"
            loading="lazy"
            width="{{ block.settings.image_2.width }}"
            height="{{ block.settings.image_2.height }}"
            class="anpc-image-{{ anpc_id }}"
          >
        {% else %}
          <div class="anpc-img-placeholder-{{ anpc_id }}">
            {{ 'image' | placeholder_svg_tag }}
            <div class="anpc-empty-state-{{ anpc_id }}">
              Add second image
            </div>
          </div>
        {% endif %}
      </a>
    {% else %}
      <div class="anpc-image-wrapper-{{ anpc_id }}">
        {% if block.settings.image_2 %}
          <img
            src="{{ block.settings.image_2 | image_url: width: 2000 }}"
            alt="{{ block.settings.image_2.alt | escape }}"
            loading="lazy"
            width="{{ block.settings.image_2.width }}"
            height="{{ block.settings.image_2.height }}"
            class="anpc-image-{{ anpc_id }}"
          >
        {% else %}
          <div class="anpc-img-placeholder-{{ anpc_id }}">
            {{ 'image' | placeholder_svg_tag }}
            <div class="anpc-empty-state-{{ anpc_id }}">
              Add second image
            </div>
          </div>
        {% endif %}
      </div>
    {% endif %}
  </div>
</div>

{% schema %}
{
  "name": "ANPC",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "First image"
    },
    {
      "type": "image_picker",
      "id": "image_1",
      "label": "Image"
    },
    {
      "type": "url",
      "id": "image_1_link",
      "label": "Link"
    },
    {
      "type": "header",
      "content": "Second image"
    },
    {
      "type": "image_picker",
      "id": "image_2",
      "label": "Image"
    },
    {
      "type": "url",
      "id": "image_2_link",
      "label": "Link"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "spacing",
      "label": "Spacing between images",
      "min": 0,
      "max": 50,
      "step": 5,
      "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "border_radius",
      "label": "Border radius",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "Desktop width",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    }
  ],
  "presets": [
    {
      "name": "ANPC"
    }
  ]
}
{% endschema %}
